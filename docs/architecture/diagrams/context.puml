@startuml Context
' Exit Guardian - Context (C4 Level 1)
!include <C4/C4_Container>


Person(user, "User")
System(exitg, "Gateway", "Alerts when leaving with windows open")
System(sensor1, "Window Sensor 1", "UID + OPEN/CLOSED + PAIR/UNPAIR + BAT STATUS")
System(sensor2, "Window Sensor 2", "UID + OPEN/CLOSED + PAIR/UNPAIR + BAT STATUS")
System(sensorN, "Window Sensor N", "UID + OPEN/CLOSED + PAIR/UNPAIR + BAT STATUS")


Rel(user, exitg, "Door opens/closes, button presses; hears buzzer/LEDs")
Rel(sensor1, exitg, "RF events (433 MHz GFSK)")
Rel(sensor2, exitg, "RF events (433 MHz GFSK)")
Rel(sensorN, exitg, "RF events (433 MHz GFSK)")


SHOW_LEGEND()
@enduml