@startuml
skinparam componentStyle rectangle
skinparam packageStyle frame

' Hide all connections (keep layout influence, hide visuals)
skinparam arrow {
    Color transparent
    FontColor transparent
}

title Gateway SW Architecture

package "Application Layer" #LightBlue {
    [Main / Super-loop] as App
    [Sensor Manager] as SensorMgr
    [Log] as Log
}

package "Mid-level Drivers" #LightGreen {
    [Board (init / systick)] as Board
    [CC1101 RF Transceiver] as CC1101
    [FeRAM (FM24xx)] as FeRAM
    [Reed Switch] as Reed
    [Push Button] as Button
    [LED] as Led
    [Buzzer] as Buzzer
}

package "Hardware Abstraction Layer (STM8L15x SPL)" #Pink {
    component "Communication" {
        [SPI] as SPI
        [I2C] as I2C
        [USART] as USART
    }
    component "Core / IO / Timing" {
        [CLK] as CLK
        [GPIO] as GPIO
        [EXTI] as EXTI
        [TIM1 (PWM)] as TIM1
        [TIM4 (1 ms tick)] as TIM4
        [ADC] as ADC
    }
}

' Application -> Mid-level
App --> Board     : init / systick / ISR dispatch
App --> SensorMgr
App --> CC1101    : RX poll (GDO0 IRQ flag)
App --> Reed      : handle / ISR
App --> Button    : handle / ISR
App --> Led       : LED_B / LED_R / LED_Y handle
App --> Buzzer    : buzzer_handle
App --> Log       : send_string

SensorMgr --> FeRAM : persist paired list (CRC16-CCITT)

' Mid-level -> HAL
Board  --> CLK
Board  --> GPIO
Board  --> EXTI
Board  --> TIM4   : 1 kHz systick
Board  --> ADC    : battery sensing
Board  --> SPI
Board  --> I2C
Board  --> USART

CC1101 --> SPI
CC1101 --> GPIO   : CS / GDOx
CC1101 --> EXTI   : GDO0 IRQ
FeRAM  --> I2C
Reed   --> GPIO
Reed   --> EXTI
Button --> GPIO
Button --> EXTI
Led    --> GPIO
Buzzer --> TIM1   : differential PWM
Log    --> USART

@enduml